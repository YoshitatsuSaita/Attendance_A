<%= turbo_frame_tag 'modal' do %>
  <div class="modal" style="display: block;" data-controller="attendance-change-request">
    <div class="modal-dialog modal-lg modal-dialog-center">
      <div class="modal-content">
        <div class="modal-header">
          <button type="button" class="close" data-action="attendance-change-request#close" aria-label="Close">
            <span aria-hidden="true">×</span>
          </button>
          <h1 class="modal-title">勤怠変更申請のお知らせ</h1>
        </div>
        <div class="modal-body">
          <% if @change_requests_by_user.empty? %>
            <p class="center">申請中・否認の勤怠変更申請はありません。</p>
          <% else %>
            <%= form_with(url: review_attendance_change_requests_path, method: :patch, data: { turbo: false }) do %>
              <%= hidden_field_tag :date, params[:date] %>
              <% @change_requests_by_user.each do |user, requests| %>
                <h4 class="attendance-change-request__applicant">【<%= user.name %> からの勤怠変更申請】</h4>
                <table class="table table-bordered table-condensed attendance-change-request__table">
                  <thead>
                    <tr>
                      <th>日付</th>
                      <th>曜日</th>
                      <th>変更前出社時間</th>
                      <th>変更後出社時間</th>
                      <th>変更前退社時間</th>
                      <th>変更後退社時間</th>
                      <th>備考</th>
                      <th>指示者確認</th>
                      <th>変更</th>
                      <th>勤怠</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% requests.each do |req| %>
                      <tr>
                        <td><%= l(req.worked_on, format: :short) %></td>
                        <td class="<%= weekday_color(req.worked_on) %>">
                          <%= days_of_the_week[req.worked_on.wday] %>
                        </td>
                        <td><%= req.before_started_at&.strftime('%H:%M') %></td>
                        <td><%= req.after_started_at&.strftime('%H:%M') %></td>
                        <td><%= req.before_finished_at&.strftime('%H:%M') %></td>
                        <td><%= req.after_finished_at&.strftime('%H:%M') %></td>
                        <td><%= req.note %></td>
                        <td>
                          <%= select_tag "attendance_change_requests[#{req.id}][status]",
                                options_for_select(attendance_change_status_options, req.status),
                                class: 'form-control' %>
                        </td>
                        <td>
                          <%= check_box_tag "attendance_change_requests[#{req.id}][apply]", '1', false %>
                        </td>
                        <td>
                          <%= link_to '確認',
                                user_path(req.user,
                                          date: req.worked_on.beginning_of_month),
                                class: 'btn btn-primary' %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              <% end %>

              <div class="center">
                <%= submit_tag '変更を反映', class: 'btn btn-primary btn-attendance-change-request' %>
                <button type="button" class="btn btn-primary btn-attendance-change-request" data-action="attendance-change-request#close">
                  閉じる
                </button>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
