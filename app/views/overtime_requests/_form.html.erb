<%= turbo_frame_tag 'modal' do %>
  <div class="modal" style="display: block;" data-controller="overtime-request">
    <div class="modal-dialog modal-lg modal-dialog-center">
      <div class="modal-content">
        <div class="modal-header">
          <button type="button" class="close" data-action="overtime-request#close" aria-label="Close">
            <span aria-hidden="true">×</span>
          </button>
          <h1 class="modal-title">残業申請</h1>
        </div>
        <div class="modal-body">
          <%= form_with(model: @overtime_request, url: overtime_requests_path, local: false, data: { action: "submit->overtime-request#submit" }) do |f| %>
            <%= render 'shared/error_messages', object: @overtime_request %>

            <%= f.hidden_field :worked_on %>
            <%= hidden_field_tag :date, params[:date] %>

            <table class="table table-bordered table-condensed overtime-request__table">
              <thead>
                <tr>
                  <th>日付</th>
                  <th>曜日</th>
                  <th>終了予定時間</th>
                  <th>翌日</th>
                  <th>業務処理内容</th>
                  <th>指示者確認（申請先）</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><%= l(@overtime_request.worked_on, format: :short) %></td>
                  <td class="<%= weekday_color(@overtime_request.worked_on) %>">
                    <%= days_of_the_week[@overtime_request.worked_on.wday] %>
                  </td>
                  <td><%= f.time_field :end_time, class: 'form-control' %></td>
                  <td><%= f.check_box :next_day %></td>
                  <td><%= f.text_field :work_content, class: 'form-control' %></td>
                  <td>
                    <%= f.collection_select :superior_id, @superiors, :id, :name,
                          { include_blank: '-- 選択 --' }, { class: 'form-control' } %>
                  </td>
                </tr>
              </tbody>
            </table>

            <div class="center">
              <%= f.submit '申請', class: 'btn btn-primary btn-overtime-request' %>
              <button type="button" class="btn btn-primary btn-overtime-request" data-action="overtime-request#close">
                キャンセル
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
